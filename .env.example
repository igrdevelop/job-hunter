# Copy this file to .env and fill in your values
# NEVER commit .env to git

TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# AUTO_APPLY=true — auto-generate docs for all new jobs (no manual buttons)
AUTO_APPLY=false

# ── LLM API config (for apply_agent.py API mode) ─────────────────────────────
# Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Model name (OPTIONAL — leave commented to use the default from hunter/config.py,
# currently claude-sonnet-4-6). Only set this to override the code default (e.g. an
# experiment or a temporary cheaper model). Keeping the model in code means future
# upgrades ship as a normal commit + deploy instead of a manual edit on the server.
# Examples:
#   anthropic: claude-haiku-4-5 (cheap), claude-sonnet-4-6 (quality)
#   openai:    gpt-4o-mini (cheap), gpt-4o (quality)
#LLM_MODEL=claude-sonnet-4-6

# API key for the chosen provider
LLM_API_KEY=sk-ant-api03-...
# or for OpenAI:
# LLM_API_KEY=sk-proj-...

# ── Independent ATS verdict + refine loop ────────────────────────────────────
# After generate_docs, one cheap-LLM call scores the RENDERED PDF (what a
# real ATS actually parses) against the job posting. If that score is below
# the target, hunter/verdict_refine.py rewrites resume_en against the
# verdict's own feedback (rounds 1-2 honest, round 3+ stretch — may add
# posting tech absent from the profile, logged to the "To Learn" column),
# re-renders, and re-verdicts, keeping only strict improvements.
# ATS_VERDICT_MAX_REFINES=0 disables the loop entirely (old one-shot verdict).
# Default 3 = two honest rounds + stretch round (owner decision 2026-07-07).
#ATS_VERDICT_TARGET=95
#ATS_VERDICT_MAX_REFINES=3

# ── PL/EN translation calls ───────────────────────────────────────────────────
# Mechanical PL<->EN translation (hunter.apply_shared._translate_resume /
# _translate_plain, used by the language enforce-gate and the verdict-refine
# PL mirror) is a Haiku-tier task, not worth the main profile's $/output-token
# rate. Defaults to the same cheap model as the claim judge; falls back to the
# main LLM profile if no key resolves (a translation must never fail outright
# for lack of a dedicated key). See docs/LLM_COST_REDUCTION_PLAN.md M5.
#TRANSLATE_PROVIDER=anthropic
#TRANSLATE_MODEL=claude-haiku-4-5-20251001
#TRANSLATE_API_KEY=sk-ant-api03-...

# ── Doomed-vacancy gate ───────────────────────────────────────────────────────
# Deterministic (regex-only, zero LLM cost) full-text screen run right after
# expired-check, before the first LLM call. HARD findings (non-Poland
# onsite/hybrid, non-EU work authorization, unsupported required language)
# write a SKIP tracker row and abort generation for $0.00; SOFT findings
# (e.g. stack mismatch) just warn in Telegram and generation continues.
# Force-mode/manual-paste always degrades HARD to warn. See
# docs/DOOMED_GATE_PLAN.md.
#DOOMED_GATE_ENABLED=true
# "skip" (default) aborts on HARD; "warn" is an emergency lever to downgrade
# every HARD finding to a warning without disabling the gate entirely.
#DOOMED_GATE_HARD_ACTION=skip

# ── CLI fallback ──────────────────────────────────────────────────────────────
# Set to true to use claude CLI instead of API (original approach, uses Pro plan)
APPLY_USE_CLI=false

# ── Resilience ────────────────────────────────────────────────────────────────
# Seconds to wait between auto-apply jobs in a batch
APPLY_DELAY_SEC=0

# Max jobs to process per single hunt run (prevents burning budget)
MAX_JOBS_PER_RUN=10

# Generate Polish resume for every application (not just PL-language postings)
GENERATE_PL_RESUME=true

# Skip generating resume_pl/cover_letter_pl/about_me_pl on the FIRST generation
# call for an English-language posting in short mode (they are ~40-50% of that
# call's output tokens and short mode never delivers them for an EN posting
# anyway). PL postings and --full runs are unaffected. See LLM_COST_REDUCTION_PLAN M4.
GEN_SKIP_PL_FOR_EN=true

# CLI mode retry on 529 overloaded errors
CLI_MAX_RETRIES=3
CLI_RETRY_DELAY=30

# ── LinkedIn session (для загрузки текста вакансий с LinkedIn) ────────────────
# БЕЗ этого файла КАЖДАЯ LinkedIn-вакансия падает на фетче (HTTP 429 в guest API)
# — это крупнейший источник FAIL-строк в трекере. Чтобы включить:
#   1. локально: python tools/linkedin_login.py  → создаст storage_state JSON
#   2. примонтировать файл в контейнер и указать путь ниже
#   3. после этого можно убрать linkedin.com из GMAIL_ENRICH_SKIP_HOSTS
# LINKEDIN_STORAGE_STATE=D:/LearningProject/Claude/.secrets/linkedin_storage_state.json

# ── Enrichment / dual-apply throttling ───────────────────────────────────────
# Хосты, для которых НЕ делать обогащение деталей в ханте (они хард-блокят →
# 429/403 и засоряют общий лимит). Стаб из письма-алерта сохраняется. После
# настройки LinkedIn-сессии убери отсюда linkedin.com.
# GMAIL_ENRICH_SKIP_HOSTS=linkedin.com,pracuj.pl
# Жёсткий потолок времени на теневой прогон dual (отдельный процесс), сек.
# DUAL_SHADOW_TIMEOUT_SEC=900

# LinkedIn auto-search
LINKEDIN_ENABLED=true
LINKEDIN_KEYWORDS=angular,frontend developer
LINKEDIN_GEO_ID=105072130

# ── linkedin_scout/ (standalone LinkedIn posts scout, owner's desktop only) ───
# NOT part of hunter/, NOT in Docker, NOT on the bot's schedule — run manually
# or via Windows Task Scheduler (see linkedin_scout/README.md). Reuses
# LINKEDIN_STORAGE_STATE above to seed its own separate Chrome profile.
# Comma-separated content-search keywords, rotated one-per-run (--track search).
# LINKEDIN_SCOUT_KEYWORDS=angular hiring,angular developer,angular praca zdalna,angular Wrocław
# Chance (0.0-1.0) a run just exits immediately without opening the browser.
# LINKEDIN_SCOUT_SKIP_CHANCE=0.30
# Max minutes of random sleep before opening the browser (0 = no wait, up to this).
# LINKEDIN_SCOUT_JITTER_MAX_MIN=45

# Relay path to the bot (owner decision 2026-07-08): the bot auto-deploys to
# its own server and does NOT share a filesystem with this script's Windows
# desktop, so a found candidate is relayed over Telegram — as the OWNER'S OWN
# user account (Telethon/MTProto), not the bot's token, since a bot never
# receives its own outgoing messages back as an incoming update. One-time
# setup: python tools/telegram_user_login.py (needs TELEGRAM_API_ID/_HASH
# below, from https://my.telegram.org).
# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789
# TELEGRAM_BOT_USERNAME=@my_job_hunter_bot
# TELEGRAM_USER_SESSION=D:/LearningProject/Claude/.secrets/telegram_user_session

# Bot-side relay (hunter/sources/linkedin_scout_relay.py) — receives the
# /scoutfound command above and drains its own queue file (now entirely on
# the bot's own filesystem) into normal Telegram Apply/Skip cards on the
# bot's own hunt cycle. No scraping, IS part of hunter/ and Docker.
# LINKEDIN_SCOUT_RELAY_ENABLED=true

# Bulldogjob source
BULLDOGJOB_ENABLED=true

# Arbeitnow (EU job board API)
ARBEITNOW_ENABLED=true

# Remotive (remote job board API)
REMOTIVE_ENABLED=true

# Remote OK (remoteok.com/api)
REMOTEOK_ENABLED=true

# Himalayas (himalayas.app/jobs/api)
HIMALAYAS_ENABLED=true

# 4dayweek.io (api/v2/jobs)
FOURDAYWEEK_ENABLED=true

# We Work Remotely (remote-jobs.rss)
WEWORKREMOTELY_ENABLED=true

# RemoteLeaf (HTML listing + pagination; fragile if layout changes)
REMOTELEAF_ENABLED=true

# ATS Aggregator (Workable/Greenhouse/Lever/Recruitee/Ashby).
# Companies listed in hunter/ats_companies.json — add entries there, no code.
ATS_AGGREGATOR_ENABLED=true

# ── Tracker / to_send backups ─────────────────────────────────────────────────
# Daily copy when hunter.py runs (JobQueue) + manual: python tools/backup_tracker.py
# TRACKER_BACKUP_ENABLED=true
# TRACKER_BACKUP_DIR=D:/LearningProject/Claude/backups
# TRACKER_BACKUP_KEEP_FILES=90
# TRACKER_BACKUP_TIME=06:05

# ── Per-source staggered schedule ─────────────────────────────────────────────
# Minutes to offset each source from the base SCHEDULE_TIMES.
# With 4 sources and offset=60, base 08:00 → 08:00 / 09:00 / 10:00 / 11:00
SCHEDULE_SOURCE_OFFSET_MIN=60
